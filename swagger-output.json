                "name": "John Doe",
                "email": "john@example.com",
                "password": "password123",
                "role": "CITIZEN"
              }
            },
            "application/xml": {
              "schema": {
                "name": "John Doe",
                "email": "john@example.com",
                "password": "password123",
                "role": "CITIZEN"
              }
            }
          }
        }
