{
  "name": "backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "nodemon src/server.js",
    "build": "tsc",
    "start": "nodemon src/server.js",
    "lint": "eslint \"src/**/*.js\" --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "k6:read": "k6 run k6/scenarios/read-heavy.js",
    "k6:write": "k6 run k6/scenarios/write-heavy.js",
    "k6:mixed": "k6 run k6/scenarios/mixed.js",
    "k6:spike": "k6 run k6/scenarios/spike.js",
    "k6:soak": "k6 run k6/scenarios/soak.js",
    "k6:all": "npm run k6:read && npm run k6:write && npm run k6:mixed && npm run k6:spike && npm run k6:soak"
  },
  "dependencies": {
    "axios": "^1.15.1",
    "bcryptjs": "^3.0.3",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "fastest-validator": "^1.19.1",
    "graphql": "^16.13.2",
    "graphql-http": "^1.22.4",
    "jsonwebtoken": "^9.0.3",
    "node-telegram-bot-api": "^0.67.0",
    "nodemailer": "^8.0.4",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8",
    "swagger-autogen": "^2.23.7",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.0.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "source-map-support": "^0.5.21"
  }
}
